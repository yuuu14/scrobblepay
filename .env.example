# Last.fm API - get a free key at https://www.last.fm/api/account/create
LASTFM_API_KEY=your_key_here
LASTFM_USER=yuuu14

# Arc wallet private key — OPTIONAL. The agent auto-generates and saves one here
# on the first `--execute` run; set this only to use an existing wallet instead.
# PRIVATE_KEY=0x...

# On-chain Splitter contract address — written automatically by
# `scripts/deploy_contract.py`. Used by the agent's --use-contract flag.
# SPLITTER_ADDRESS=0x...

